# Google Places API (New) — get from console.cloud.google.com
GOOGLE_PLACES_API_KEY=

# Supabase — same credentials as the main site
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — for email notifications
RESEND_API_KEY=

# Notification settings
NOTIFY_EMAIL=v.srezovski@gmail.com
NOTIFY_FROM=hello@greasetrapflorida.com

# Vercel deploy hook — triggers site rebuild
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/prj_S1rQUI4G1T4gw2fxr8bUZ7mi78Dv/jjDgzUDO9T

# Mode: "expansion" | "weekly" | "monthly"
MODE=weekly

# Set to "true" to run without making any changes to the database or triggering rebuilds
DRY_RUN=false
