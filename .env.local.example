# ===========================================
# Grease Trap Florida — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values.
# Never commit .env.local to version control.

# Supabase — get from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=              # Project URL (https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # anon/public key
SUPABASE_SERVICE_ROLE_KEY=             # service_role key (server-only, never expose to client)

# Resend — transactional email (https://resend.com/api-keys)
RESEND_API_KEY=                        # Resend API key (re_xxxxx)
RESEND_FROM_EMAIL=hello@greasetrapflorida.com  # Verified sender address
ADMIN_EMAIL=                           # Where lead/claim notifications go

# Site
NEXT_PUBLIC_SITE_URL=https://greasetrapflorida.com  # Canonical site URL (no trailing slash)
NEXT_PUBLIC_SITE_NAME=Grease Trap Florida            # Display name used in meta tags

# Apify — Google Maps scraping (https://console.apify.com/account/integrations)
APIFY_TOKEN=                           # Apify API token (used in data collection scripts)

# Claude API — data enrichment (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=                     # Anthropic API key (used in enrichment scripts)

# Stripe — featured listing payments (https://dashboard.stripe.com/payment-links)
NEXT_PUBLIC_STRIPE_FEATURED_LINK=      # Stripe Payment Link URL for $49/mo featured listing

# Google Analytics (add when ready)
NEXT_PUBLIC_GA_ID=                     # GA4 Measurement ID (G-XXXXXXXXXX)

# Google AdSense (add when approved)
NEXT_PUBLIC_ADSENSE_PUB_ID=            # AdSense Publisher ID (ca-pub-XXXXXXXX)
